{
  "agents": {
    "defaults": {
      "workspace": "C:\\Users\\ASUS\\.openclaw\\workspace",
      "models": {
        "openai/gpt-5.5": {
          "alias": "GPT"
        }
      },
      "model": {
        "primary": "openai/gpt-5.5"
      }
    }
  },

  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "eca89116dc38143ce692d733d290850697fe90f11af3a86c"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": true
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },

  "session": {
    "dmScope": "per-channel-peer"
  },

  "tools": {
    "profile": "coding"
  },

  "plugins": {
    "allow": [
      "openai",
      "whatsapp"
    ],
    "entries": {
      "openai": {
        "enabled": true
      },
      "whatsapp": {
        "enabled": true
      }
    }
  },

  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },

  "channels": {
    "whatsapp": {
      "enabled": true,
      "selfChatMode": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "allowFrom": [
        "whatsapp:9633884342",
        "whatsapp:+919633884342"
      ]
    }
  },


  "commands": {
    "ownerAllowFrom": [
      "whatsapp:9633884342",
      "whatsapp:+919633884342"
    ]
  },

  "meta": {
    "lastTouchedVersion": "2026.5.12"
  },

  "wizard": {
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  }
}